{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "declaration": true
  },
  "include": ["doge/**/*", "relayer/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist", "lib"]
}
